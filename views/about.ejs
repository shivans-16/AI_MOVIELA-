
<% layout("/layouts/boilerplate") %> 




<style>
    body {
  /* background-color: #000; */
      background: rgb(15, 23, 42);
  color: #fff;
  font-family: 'Segoe UI', sans-serif;
  margin: 0;
  padding: 0;
}

.about-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80px 20px;
  min-height: 80vh;
}

.about-card {
  background: rgba(255, 255, 255, 0.05);
  padding: 40px;
  border-radius: 20px;
  max-width: 700px;
  text-align: center;
  box-shadow: 0 0 20px rgba(0, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.about-title {
  font-size: 2.5rem;
  color: #ffcc70;
  margin-bottom: 20px;
  font-weight: bold;
}

.about-description {
  font-size: 1.1rem;
  line-height: 1.6;
  color: #ddd;
}

</style>

<div class="about-container">
  <div class="about-card">
    <h1 class="about-title">AI-MovieLA</h1>
    <p class="about-description">
      AI-MovieLA is your intelligent movie companion, designed to eliminate endless scrolling and deliver cinematic joy. Powered by advanced AI, it analyzes your mood, preferences, and watch history to recommend films you'll genuinely love. Whether you're into thrillers, rom-coms, or hidden indie gems, AI-MovieLA curates a personalized experience that evolves with you. It's not just a movie app — it's your gateway to smarter entertainment discovery.
    </p>
  </div>
</div>

