
<% layout("/layouts/boilerplate") %> 

<style>
  .about-hero {
    padding: 120px 20px 80px;
    text-align: center;
    background: radial-gradient(circle at top, rgba(229, 9, 20, 0.05), transparent 70%);
  }

  .about-hero h1 {
    font-size: 4rem;
    font-weight: 900;
    margin-bottom: 20px;
    background: linear-gradient(to right, #fff, #e50914);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -2px;
  }

  .about-hero p {
    font-size: 1.4rem;
    color: #aaa;
    max-width: 800px;
    margin: 0 auto;
  }

  .about-sections {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
    margin-top: 60px;
  }

  .about-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 40px;
    border-radius: 24px;
    transition: all 0.4s ease;
  }

  .about-card:hover {
    transform: translateY(-10px);
    border-color: rgba(229, 9, 20, 0.3);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .about-card i {
    font-size: 2.5rem;
    color: #e50914;
    margin-bottom: 20px;
  }

  .about-card h3 {
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 15px;
  }

  .about-card p {
    color: #ccc;
    line-height: 1.7;
  }

  .mission-section {
    display: flex;
    align-items: center;
    gap: 60px;
    margin-top: 100px;
    padding: 80px 40px;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .mission-content {
    flex: 1;
  }

  .mission-image {
    flex: 1;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.6);
  }

  .mission-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .mission-content h2 {
    font-size: 2.8rem;
    color: #fff;
    margin-bottom: 25px;
  }

  .mission-content p {
    font-size: 1.15rem;
    color: #bbb;
    margin-bottom: 30px;
    line-height: 1.8;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-top: 60px;
    text-align: center;
  }

  .stat-item h4 {
    font-size: 2.5rem;
    color: #e50914;
    font-weight: 900;
  }

  .stat-item p {
    color: #777;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .mission-section {
      flex-direction: column;
      padding: 40px 20px;
    }
    .about-hero h1 { font-size: 3rem; }
  }
</style>

<div class="about-hero reveal">
  <h1>Beyond Discovery</h1>
  <p>AI-MovieLA uses advanced neural engines to redefine how you experience cinema. We don't just find movies; we find stories that resonate with your soul.</p>
</div>

<div class="about-sections">
  <div class="about-grid">
    <div class="about-card reveal">
      <i class="fas fa-brain"></i>
      <h3>Neural Matching</h3>
      <p>Our AI analyzes over 50 data points per movie—from color palettes to emotional arcs—to find your perfect match.</p>
    </div>
    <div class="about-card reveal" style="transition-delay: 0.2s;">
      <i class="fas fa-bolt"></i>
      <h3>Zero-Scroll Era</h3>
      <p>Stop wasting time. Our curated "Moodboards" take you from "What to watch?" to "Play" in under 10 seconds.</p>
    </div>
    <div class="about-card reveal" style="transition-delay: 0.4s;">
      <i class="fas fa-shield-halved"></i>
      <h3>Privacy First</h3>
      <p>Your watch history is yours. All AI processing happens with anonymized data, keeping your profile secure.</p>
    </div>
  </div>

  <div class="mission-section reveal">
    <div class="mission-content">
      <h2>The Mission</h2>
      <p>In a world of infinite choices, simplicity is the ultimate luxury. Our mission is to strip away the noise of streaming platforms and bring back the magic of the "Great Movie Night".</p>
      <p>Whether you're looking for a deep emotional journey or just a high-octane distraction, AI-MovieLA understands the context of your life to deliver the right film at the right time.</p>
      
      <div class="stat-grid">
        <div class="stat-item">
          <h4>5M+</h4>
          <p>Scanned Titles</p>
        </div>
        <div class="stat-item">
          <h4>98%</h4>
          <p>Accuracy Rate</p>
        </div>
        <div class="stat-item">
          <h4>24/7</h4>
          <p>AI Training</p>
        </div>
      </div>
    </div>
    <div class="mission-image">
      <img src="https://images.unsplash.com/photo-1536440136628-849c177e76a1?auto=format&fit=crop&q=80&w=1025&ixlib=rb-4.0.3" alt="Cinema Experience">
    </div>
  </div>
</div>

<script>
  // Simple scroll reveal observer
  const observerOptions = {
    threshold: 0.1
  };

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
</script>

