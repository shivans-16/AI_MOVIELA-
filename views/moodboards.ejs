<% layout("/layouts/boilerplate") %>

  <style>
    /* body{
    background: rgb(15, 23, 42);
  } */
    body {
      background: rgb(17, 22, 41);
    }

    .wishlist-container {
      padding: 3rem 2rem;
      text-align: center;
    }

    .wishlist-heading {
      font-size: 2.8rem;
      color: #fff;
      margin-bottom: 2rem;
      text-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    }



    .scroll-row {
      display: flex;
      gap: 2rem;
      overflow-x: auto;
      padding-bottom: 1rem;
    }

    .movie-card {
      min-width: 260px;
      height: 400px;
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
      border-radius: 16px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .movie-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.4);
    }

    .card-image {
      flex: 0 0 70%;
      height: 70%;
      overflow: hidden;
    }

    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .card-details {
      flex: 0 0 30%;
      padding: 0.8rem;
      color: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
    }

    .card-details h3 {
      margin: 0;
      font-size: 1.1rem;
      text-align: center;
    }

    .card-details .genre,
    .card-details .year {
      font-size: 0.9rem;
      opacity: 0.85;
      margin: 0.2rem 0;
    }

    .remove-btn {
      background-color: #ff4d4d;
      color: #fff;
      border: none;
      padding: 0.4rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      transition: background-color 0.3s ease;
    }

    .remove-btn:hover {
      background-color: #e60000;
    }
  </style>

  <div class="wishlist-container">
    <h1 class="wishlist-heading">My Watchlist</h1>



    <div class="scroll-row">
      <% wishlist.forEach(movie=> { %>
        <div class="movie-card">
          <div class="card-image">
            <img src="<%= movie.image %>" alt="<%= movie.title %>" />
          </div>
          <div class="card-details">
            <h3>
              <%= movie.title %>
            </h3>
            <p class="genre">
              <%= movie.genre %>
            </p>
            <p class="year">
              <%= movie.releaseYear %>
            </p>
            <form action="/wishlist/remove/<%=movie._id%>" method="POST">
              <button class="remove-btn">Remove</button>
            </form>
          </div>
        </div>
        <% }) %>
    </div>
  </div>