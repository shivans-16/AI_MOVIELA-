<% layout('layouts/boilerplate') %>

<div class="upgrade-container">
    <div class="upgrade-header">
        <h1>Elevate Your Movie Experience</h1>
        <p>Choose the plan that's right for you and unlock premium features.</p>
    </div>

    <div class="pricing-grid">
        <!-- Free Plan -->
        <div class="pricing-card card-free">
            <div class="card-glass-base">
                <div class="plan-name">Free</div>
                <div class="plan-price">$0<span>/month</span></div>
                <ul class="plan-features">
                    <li><i class="fas fa-check"></i> Standard Movie Search</li>
                    <li><i class="fas fa-check"></i> basic AI Recommendations</li>
                    <li><i class="fas fa-check"></i> Create up to 2 Moodboards</li>
                    <li><i class="fas fa-times"></i> Ad-free Experience</li>
                    <li><i class="fas fa-times"></i> Priority AI Processing</li>
                    <li><i class="fas fa-times"></i> Exclusive Preview Content</li>
                </ul>
                <div class="current-plan-badge">Current Plan</div>
            </div>
        </div>

        <!-- Pro Plan -->
        <div class="pricing-card card-pro">
            <div class="card-glass-base">
                <div class="pro-tag">Recommended</div>
                <div class="plan-name">Pro</div>
                <div class="plan-price">$9.99<span>/month</span></div>
                <ul class="plan-features">
                    <li><i class="fas fa-check"></i> Advanced AI Deep Search</li>
                    <li><i class="fas fa-check"></i> Personalized 1-on-1 Recs</li>
                    <li><i class="fas fa-check"></i> Unlimited Moodboards</li>
                    <li><i class="fas fa-check"></i> Pure Ad-free Experience</li>
                    <li><i class="fas fa-check"></i> Lightning Fast AI Processing</li>
                    <li><i class="fas fa-check"></i> Early Access to New Features</li>
                </ul>
                <button class="upgrade-btn">Upgrade</button>
            </div>
        </div>
    </div>
</div>
