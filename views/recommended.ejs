<% layout("/layouts/boilerplate") %>

<style>
    body {
  background-color: #0f0c29;
  font-family: 'Segoe UI', sans-serif;
  margin: 0;
  padding: 0;
  color: white;
}

.recommended-container {
  padding: 40px 60px;
}

.recommended-heading {
  font-size: 2.8rem;
  text-align: center;
  color: #ff4da6;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px);
  padding: 1rem 2rem;
  border-radius: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  margin-bottom: 40px;
}

.movie-grid {
  display: flex; 
  justify-content: center; 
  gap: 30px; 
  padding-bottom: 40px; 
  flex-wrap: wrap; 
  margin-top: 20px;
}

</style>

<div class="recommended-container">
  <h1 class="recommended-heading">❤️ Recommended For You (<%= recommendedGenre || 'Mixed' %>)</h1>

  <% if (movies && movies.length > 0) { %>
    <div class="movie-grid">
      <% movies.forEach(movie => { %>
        <div class="movie-card" style="width: 280px; transform-style: preserve-3d; background: rgba(255, 255, 255, 0.06); backdrop-filter: blur(10px); border-radius: 12px; overflow: hidden; box-shadow: 0 8px 20px rgba(0,0,0,0.3); transition: transform 0.3s;">
          <div class="card-image" style="height: 380px;">
            <img src="<%= movie.image %>" alt="<%= movie.title %>" style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px 12px 0 0;" />
            <div class="card-title" style="font-size: 1.1rem; padding: 15px;"><%= movie.title %></div>
          </div>
          <div class="card-meta" style="padding: 15px; font-weight: bold; font-size: 1rem;">
            <span style="color: #e50914;"><%= movie.genre %></span> • <%= movie.releaseYear || movie.year %>
          </div>
          <div class="viewbtn" style="margin-bottom: 15px; width: 120px; margin-left: auto; margin-right: auto; background: transparent; border: 1px solid #e50914; border-radius: 8px;">
            <a class="view" href="/movie-la/show/<%=movie._id%>" style="color: #fff; width: 100%; text-align: center; padding: 10px; display: block; text-decoration: none;">View Details</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p style="text-align: center; color: #aaa;">No recommendations found yet. Keep exploring and adding to your Wishlist!</p>
  <% } %>
</div>

<script>

  document.querySelectorAll('.movie-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.transform = 'translateY(-6px)';
      card.style.boxShadow = '0 12px 28px rgba(0,0,0,0.4)';
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'translateY(0)';
      card.style.boxShadow = '0 8px 20px rgba(0,0,0,0.3)';
    });
  });
</script>
