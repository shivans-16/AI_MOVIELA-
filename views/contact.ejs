<% layout("/layouts/boilerplate") %>

  <style>
    .contact-wrapper {
      padding: 100px 20px;
      background: radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.05), transparent 60%);
      min-height: 90vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .contact-island {
      display: flex;
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(30px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 40px;
      max-width: 1100px;
      width: 100%;
      overflow: hidden;
      box-shadow: 0 50px 100px rgba(0, 0, 0, 0.5);
    }

    .contact-info-panel {
      flex: 1;
      padding: 60px;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.02));
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .contact-info-panel h2 {
      font-size: 3rem;
      font-weight: 800;
      margin-bottom: 20px;
      color: #fff;
    }

    .contact-info-panel p {
      font-size: 1.1rem;
      color: #aaa;
      margin-bottom: 40px;
      line-height: 1.6;
    }

    .contact-details {
      list-style: none;
      padding: 0;
    }

    .contact-details li {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 25px;
      color: #eee;
      font-size: 1.1rem;
    }

    .contact-details i {
      width: 50px;
      height: 50px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 15px;
      display: flex;
      justify-content: center;
      align-items: center;
      color: #e50914;
      font-size: 1.2rem;
    }

    .contact-form-panel {
      flex: 1.2;
      padding: 60px;

      background: rgba(255, 255, 255, 0.07);
    }

    .premium-form .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }

    .input-box {
      margin-bottom: 20px;
      position: relative;
    }

    .input-box label {
      display: block;
      color: #bbb;
      margin-bottom: 8px;
      font-size: 0.9rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .premium-form input,
    .premium-form textarea,
    .premium-form select {
      width: 100%;
      padding: 16px 20px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 16px;
      color: #fff;
      font-size: 1rem;
      transition: all 0.3s ease;
    }

    .premium-form input:focus,
    .premium-form textarea:focus {
      background: rgba(255, 255, 255, 0.1);
      border-color: #fff;
      outline: none;
      box-shadow: 0 0 15px rgba(255, 255, 255, 0.1);
    }

    .submit-btn {
      width: 100%;
      padding: 20px;
      background: #fff;
      color: #000;
      border: none;
      border-radius: 16px;
      font-size: 1.1rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      margin-top: 10px;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
    }

    .submit-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px rgba(255, 255, 255, 0.2);
      filter: brightness(1.1);
    }

    .submit-btn i {
      transition: transform 0.3s ease;
    }

    .submit-btn:hover i {
      transform: translateX(5px);
    }

    @media (max-width: 900px) {
      .contact-island {
        flex-direction: column;
      }

      .contact-info-panel,
      .contact-form-panel {
        padding: 40px 30px;
      }

      .premium-form .form-row {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="contact-wrapper">
    <div class="contact-island reveal">
      <div class="contact-info-panel">
        <h2>Get in Touch</h2>
        <p>Have a question or feedback? Our team of movie enthusiasts and AI experts is ready to help you discover your
          next obsession.</p>

        <ul class="contact-details">
          <li>
            <i class="fas fa-envelope"></i>
            <div>
              <strong>Email Us</strong><br>
              <span>support@aimoviela.com</span>
            </div>
          </li>
          <li>
            <i class="fas fa-phone"></i>
            <div>
              <strong>Call Us</strong><br>
              <span>+1 (555) AI-MOVIE</span>
            </div>
          </li>
          <li>
            <i class="fas fa-location-dot"></i>
            <div>
              <strong>Headquarters</strong><br>
              <span>Cinematic Valley, CA</span>
            </div>
          </li>
        </ul>
      </div>

      <div class="contact-form-panel glass-white">
        <form id="contactForm" class="premium-form">
          <div class="form-row">
            <div class="input-box">
              <label>Full Name</label>
              <input type="text" name="name" placeholder="John Doe" required>
            </div>
            <div class="input-box">
              <label>Email Address</label>
              <input type="email" name="email" placeholder="john@example.com" required>
            </div>
          </div>

          <div class="form-row">
            <div class="input-box">
              <label>Phone Number</label>
              <input type="tel" name="phone" placeholder="+1 234 567 890">
            </div>
            <div class="input-box">
              <label>Subject</label>
              <select name="subject">
                <option value="general">General Inquiry</option>
                <option value="support">Technical Support</option>
                <option value="billing">Billing Question</option>
                <option value="feedback">Product Feedback</option>
              </select>
            </div>
          </div>

          <div class="input-box">
            <label>How can we help?</label>
            <textarea name="message" rows="5" placeholder="Tell us what's on your mind..." required></textarea>
          </div>

          <button type="submit" class="submit-btn" id="submitBtn">
            <span>Send Message</span>
            <i class="fas fa-paper-plane"></i>
          </button>
        </form>
      </div>
    </div>
  </div>


  <div class="success-modal-overlay" id="successOverlay">
    <div class="success-modal">
      <div class="success-icon">
        <i class="fas fa-check"></i>
      </div>
      <h2>Message Sent!</h2>
      <p>Thank you for reaching out. Our team has received your message and will get back to you within 24 hours.</p>
      <button class="success-close-btn" onclick="closeSuccessModal()">Great, thanks!</button>
    </div>
  </div>

  <script>

    setTimeout(() => {
      document.querySelector('.reveal').classList.add('active');
    }, 100);

    const contactForm = document.getElementById('contactForm');
    const successOverlay = document.getElementById('successOverlay');
    const submitBtn = document.getElementById('submitBtn');

    contactForm.addEventListener('submit', function (e) {
      e.preventDefault();


      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span>Sending...</span> <i class="fas fa-spinner fa-spin"></i>';


      setTimeout(() => {

        successOverlay.classList.add('active');


        contactForm.reset();


        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span>Send Message</span> <i class="fas fa-paper-plane"></i>';


        setTimeout(() => {
          window.location.href = '/movie-la';
        }, 2000);
      }, 1500);
    });

    function closeSuccessModal() {
      successOverlay.classList.remove('active');
      window.location.href = '/movie-la';
    }
  </script>