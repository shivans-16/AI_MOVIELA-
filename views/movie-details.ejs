<% layout("/layouts/boilerplate") %> 
<style>
.details-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: calc(100vh - 150px);
  padding: 40px;
  background: url('<%= movie.Poster %>') no-repeat center center fixed;
  background-size: cover;
  position: relative;
}

.details-wrapper::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(15px);
  z-index: 1;
}

.details-card {
  position: relative;
  z-index: 2;
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 24px;
  width: 1000px;
  max-width: 95%;
  overflow: hidden;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6);
  color: #fff;
  animation: cardSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.close-btn {
  position: absolute;
  top: 20px;
  right: 25px;
  font-size: 2rem;
  color: rgba(255, 255, 255, 0.6);
  text-decoration: none;
  transition: color 0.3s, transform 0.3s;
  z-index: 10;
}

.close-btn:hover {
  color: #ff4da6;
  transform: rotate(90deg);
}

.details-left {
  flex: 0 0 400px;
  padding: 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0, 0, 0, 0.2);
}

.details-left img {
  width: 100%;
  border-radius: 16px;
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
  margin-bottom: 25px;
}

.details-right {
  flex: 1;
  padding: 50px 50px 50px 20px;
  overflow-y: auto;
  max-height: 80vh;
}

.movie-title {
  font-size: 3rem;
  font-weight: 800;
  color: #b084f9;
  margin: 0 0 10px 0;
  line-height: 1.1;
}

.movie-meta {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 25px;
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
}

.rating-grid {
  display: flex;
  gap: 20px;
  margin-bottom: 35px;
  flex-wrap: wrap;
}

.rating-item {
  background: rgba(255, 255, 255, 0.08);
  padding: 12px 20px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  text-align: center;
}

.rating-value {
  display: block;
  font-size: 1.4rem;
  font-weight: 800;
  color: #fff;
}

.rating-source {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.5);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.info-section {
  margin-bottom: 30px;
}

.info-label {
  font-size: 0.9rem;
  font-weight: bold;
  color: #ff4da6;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 8px;
  display: block;
}

.info-content {
  font-size: 1.1rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.where-to-watch {
  margin-top: 40px;
  padding-top: 30px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.platform-links {
  display: flex;
  gap: 15px;
  margin-top: 15px;
  flex-wrap: wrap;
}

.platform-btn {
  padding: 10px 18px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  text-decoration: none;
  font-size: 0.9rem;
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s;
}

.platform-btn:hover {
  background: #ff4da6;
  border-color: #ff4da6;
  transform: translateY(-3px);
}

@keyframes cardSlideUp {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 992px) {
  .details-card {
    flex-direction: column;
    width: 100%;
  }
  .details-left {
    flex: 0 0 auto;
    width: 100%;
  }
  .details-right {
    padding: 30px;
  }
}
</style>

<div class="details-wrapper">
  
  <div class="details-card">
    <!-- Close -->
    <a href="/movie-la/show/<%= movie._id %>" class="close-btn">&times;</a>

    <!-- Poster Info -->
    <div class="details-left">
      <img src="<%= movie.Poster || movie.image %>" alt="<%= movie.Title %> Poster">
      <div class="info-section" style="width: 100%;">
        <span class="info-label">Director</span>
        <p class="info-content"><%= movie.Director || "N/A" %></p>
      </div>
      <div class="info-section" style="width: 100%;">
        <span class="info-label">Cast</span>
        <p class="info-content"><%= movie.Actors || "N/A" %></p>
      </div>
    </div>

    <!-- Detail Content -->
    <div class="details-right">
      <h1 class="movie-title"><%= movie.Title || movie.title %></h1>
      
      <div class="movie-meta">
        <span>🗓️ <%= movie.Year || movie.year || movie.releaseYear %></span>
        <span>⏱️ <%= movie.Runtime || "N/A" %></span>
        <span>🎭 <%= movie.Genre || movie.genre %></span>
      </div>

      <div class="rating-grid">
        <% if (movie.Ratings && movie.Ratings.length > 0) { %>
          <% movie.Ratings.forEach(rating => { %>
            <div class="rating-item">
              <span class="rating-value">
                <% if (rating.Source === "Internet Movie Database") { %> ⭐ <% } %>
                <% if (rating.Source === "Rotten Tomatoes") { %> 🍅 <% } %>
                <% if (rating.Source === "Metacritic") { %> Ⓜ️ <% } %>
                <%= rating.Value %>
              </span>
              <span class="rating-source"><%= rating.Source %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div class="rating-item">
            <span class="rating-value">N/A</span>
            <span class="rating-source">Ratings Not Available</span>
          </div>
        <% } %>
      </div>

      <div class="info-section">
        <span class="info-label">Plot Summary</span>
        <p class="info-content"><%= movie.Plot || movie.description || "No detailed description available." %></p>
      </div>

      <div class="info-section">
        <span class="info-label">Awards</span>
        <p class="info-content"><%= movie.Awards || "N/A" %></p>
      </div>

      <div class="where-to-watch">
        <span class="info-label">Where to Watch</span>
        <div class="platform-links">
          <% const watchTitle = encodeURIComponent(movie.Title || movie.title); %>
          <a href="https://www.netflix.com/search?q=<%= watchTitle %>" target="_blank" class="platform-btn">Netflix</a>
          <a href="https://www.amazon.com/s?k=<%= watchTitle %>&i=instant-video" target="_blank" class="platform-btn">Prime Video</a>
          <a href="https://www.google.com/search?q=watch+<%= watchTitle %>+online" target="_blank" class="platform-btn">Google Search</a>
        </div>
      </div>

    </div>
  </div>

</div>
