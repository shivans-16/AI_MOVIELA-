<div class="results-container">
  <h1 class="results-heading">AI Searched Movies for You</h1>

  <% if (movies.length === 0) { %>
    <p class="no-results">No movies found for selected filters.</p>
  <% } else { %>
    <div class="<%= movies.length === 1 ? 'centered-card' : 'scroll-row' %>">
      <% movies.forEach(movie => { %>
        <div class="movie-card">
          <img src="<%= movie.image %>" alt="<%= movie.title %>">
          <div class="card-info">
            <h3><%= movie.title %></h3>
            <p><%= movie.genre %> | <%= movie.year %></p>
            <button class="view-btn" onclick="showDetails('<%= movie._id %>')">View</button>
            
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Detail Box -->
  <div id="detail-box" class="detail-box hidden">
    <button class="close-btn" onclick="hideDetails()">❌</button>
    <img id="detail-image" src="" alt="">
    <div class="detail-info">
      <h2 id="detail-title"></h2>
      <p id="detail-genre"></p>
      <p id="detail-year"></p>
      <p id="detail-rating"></p>
      <p id="detail-description"></p>
    </div>
  </div>  
  

