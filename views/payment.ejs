<% layout('layouts/boilerplate') %>

    <div class="payment-wrapper">
        <!-- Animated Whitish Fumes Background -->
        <div class="fume-container">
            <div class="fume fume-1"></div>
            <div class="fume fume-2"></div>
            <div class="fume fume-3"></div>
        </div>

        <div class="payment-container">
            <div class="payment-header">
                <h1>Complete Your Upgrade</h1>
                <p>Unlock the full power of AI-MovieLA. Premium features are just a step away.</p>
            </div>

            <div class="payment-grid">
                <!-- Left: Order Summary -->
                <div class="payment-card summary-card">
                    <div class="card-glass">
                        <h3>Order Summary</h3>
                        <div class="summary-item">
                            <span>Pro Plan Monthly</span>
                            <span>₹899</span>
                        </div>
                        <div class="summary-item">
                            <span>Platform Fee</span>
                            <span>$0.00</span>
                        </div>
                        <hr>
                        <div class="summary-total">
                            <span>Total Amount</span>
                            <span>₹899</span>
                        </div>
                        <div class="secure-badge">
                            <i class="fas fa-shield-alt"></i> 100% Secure Transaction
                        </div>
                    </div>
                </div>

                <!-- Right: Payment Methods -->
                <div class="payment-card methods-card">
                    <div class="card-glass">
                        <h3>Select Payment Method</h3>

                        <div class="method-options">
                            <!-- UPI -->
                            <div class="payment-method active" data-method="upi">
                                <div class="method-info">
                                    <i class="fas fa-mobile-alt"></i>
                                    <span>UPI (GPay, PhonePe, Paytm)</span>
                                </div>
                                <i class="fas fa-chevron-right"></i>
                            </div>

                            <!-- Cards -->
                            <div class="payment-method" data-method="card">
                                <div class="method-info">
                                    <i class="fas fa-credit-card"></i>
                                    <span>Debit / Credit Card</span>
                                </div>
                                <i class="fas fa-chevron-right"></i>
                            </div>

                            <!-- Net Banking -->
                            <div class="payment-method" data-method="netbanking">
                                <div class="method-info">
                                    <i class="fas fa-university"></i>
                                    <span>Net Banking</span>
                                </div>
                                <i class="fas fa-chevron-right"></i>
                            </div>

                            <!-- Wallet -->
                            <div class="payment-method" data-method="wallet">
                                <div class="method-info">
                                    <i class="fas fa-wallet"></i>
                                    <span>Wallets</span>
                                </div>
                                <i class="fas fa-chevron-right"></i>
                            </div>
                        </div>

                        <div class="payment-actions">
                            <button id="pay-now-btn" class="pay-btn">
                                Pay ₹899 Securely
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        document.querySelectorAll('.payment-method').forEach(method => {
            method.addEventListener('click', () => {
                document.querySelectorAll('.payment-method').forEach(m => m.classList.remove('active'));
                method.classList.add('active');
            });
        });

        document.getElementById('pay-now-btn').addEventListener('click', async function () {
            const btn = this;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Initializing...';
            btn.disabled = true;

            try {
                // 1. Create Order on Backend
                const response = await fetch('/api/create-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (!data.success) {
                    throw new Error(data.message || 'Failed to create order');
                }

                // 2. Open Razorpay Checkout
                const options = {
                    key: data.key_id,
                    amount: data.amount,
                    currency: "INR",
                    name: "AI-MovieLA",
                    description: "Upgrade to Pro Plan",
                    image: "/images/logo.png", // Replace with your actual logo path
                    order_id: data.order_id,
                    handler: async function (response) {
                        // 3. Verify Payment on Backend
                        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Verifying...';

                        const verifyRes = await fetch('/api/verify-payment', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_signature: response.razorpay_signature
                            })
                        });

                        const verifyData = await verifyRes.json();

                        if (verifyData.success) {
                            alert('Payment Successful! Welcome to Pro.');
                            window.location.href = '/movie-la';
                        } else {
                            alert('Payment verification failed: ' + verifyData.message);
                            btn.disabled = false;
                            btn.innerHTML = originalText;
                        }
                    },
                    prefill: {
                        name: "<%= currentUser.username %>",
                        email: "<%= currentUser.email || '' %>"
                    },
                    theme: {
                        color: "#6366f1"
                    }
                };





                const rzp = new Razorpay(options);
                rzp.open();

                rzp.on('payment.failed', function (response) {
                    alert('Payment Failed: ' + response.error.description);
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                });

            } catch (err) {
                console.error(err);
                alert('Error: ' + err.message);
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });
    </script>