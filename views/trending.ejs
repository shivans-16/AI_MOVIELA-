<% layout("/layouts/boilerplate") %>

<style>
  body {
     background: rgb(15, 23, 42);
  /* background-color: #0f0c29; */
  font-family: 'Segoe UI', sans-serif;
  color: white;
  margin: 0;
  padding: 0;
}

.trending-container {
  padding: 60px 40px;
}

.section {
  margin-bottom: 60px;
}

.section-title {
  font-size: 2rem;
  color: #ffcc70;
  margin-bottom: 20px;
  border-left: 5px solid #ff4da6;
  padding-left: 12px;
}

/* Scroll Row */
.scroll-row {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  padding-bottom: 10px;
}

.scroll-row::-webkit-scrollbar {
  height: 8px;
}

.scroll-row::-webkit-scrollbar-thumb {
  background-color: #ff4da6;
  border-radius: 4px;
}

/* Movie Card Styling */
.movie-card {
  min-width: 260px;
  height: 400px;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
  border-radius: 16px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  scroll-snap-align: start;
  position: relative;
}

.movie-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 8px 12px rgba(233, 155, 155, 0.4);
}

/* Poster Image */
.movie-card img {
  width: 100%;
  height: 65%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.movie-card:hover img {
  transform: scale(1.05);
}

/* Info Section */
.card-info {
  padding: 16px;
  background-color: #2e2e3a;
  height: 35%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
}

.card-info h3 {
  font-size: 1.2rem;
  margin: 0;
  color: #ffcc70;
}

.card-info p {
  font-size: 0.95rem;
  color: #ccc;
  margin-top: 8px;
}

/* Date Badge */
.date-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background-color: orange;
  color: black;
  font-weight: bold;
  padding: 6px 10px;
  border-radius: 8px;
  font-size: 0.85rem;
}

</style>

<div class="trending-container">
  <!-- Section: Latest Bollywood -->
  <div class="section">
    <h2 class="section-title">Latest Bollywood</h2>
    <div class="scroll-row">
      <% bollywood.forEach(movie => { %>
        <a href="/movie-la/import-omdb/<%= movie.imdbID %>" class="movie-card" style="text-decoration: none; color: inherit;">
          <div class="date-badge"><%= movie.date %></div>
          <img src="<%= movie.image %>" alt="<%= movie.title %>">
          <div class="card-info">
            <h3><%= movie.title %></h3>
            <p><%= movie.releaseYear %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>

  <!-- Section: Trending Hollywood -->
  <div class="section">
    <h2 class="section-title">Trending Hollywood</h2>
    <div class="scroll-row">
      <% hollywood.forEach(movie => { %>
        <a href="/movie-la/import-omdb/<%= movie.imdbID %>" class="movie-card" style="text-decoration: none; color: inherit;">
          <div class="date-badge"><%= movie.date %></div>
          <img src="<%= movie.image %>" alt="<%= movie.title %>">
          <div class="card-info">
            <h3><%= movie.title %></h3>
            <p><%= movie.releaseYear %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>

  <!-- Section: South Indian Blockbusters -->
  <div class="section">
    <h2 class="section-title">South Indian Blockbusters</h2>
    <div class="scroll-row">
      <% south.forEach(movie => { %>
        <a href="/movie-la/import-omdb/<%= movie.imdbID %>" class="movie-card" style="text-decoration: none; color: inherit;">
          <div class="date-badge"><%= movie.date %></div>
          <img src="<%= movie.image %>" alt="<%= movie.title %>">
          <div class="card-info">
            <h3><%= movie.title %></h3>
            <p><%= movie.releaseYear %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>

  <!-- Section: Korean Dramas -->
  <div class="section">
    <h2 class="section-title">Korean Dramas</h2>
    <div class="scroll-row">
      <% korean.forEach(movie => { %>
        <a href="/movie-la/import-omdb/<%= movie.imdbID %>" class="movie-card" style="text-decoration: none; color: inherit;">
          <div class="date-badge"><%= movie.date %></div>
          <img src="<%= movie.image %>" alt="<%= movie.title %>">
          <div class="card-info">
            <h3><%= movie.title %></h3>
            <p><%= movie.releaseYear %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</div>
